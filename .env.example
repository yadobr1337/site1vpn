# Core application. Keep DATABASE_URL unchanged when using the bundled SQLite setup.
DATABASE_URL="file:./production.db"
NEXTAUTH_URL="https://the1vpn.ru"
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# The seed command creates or updates this administrator.
ADMIN_EMAIL="admin@the1vpn.ru"
ADMIN_PASSWORD="replace-with-a-strong-password-of-at-least-8-characters"

# Optional hCaptcha. Leave both values empty and keep CAPTCHA disabled in admin to disable it.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET_KEY=""

# Telegram linking and lifecycle notifications.
# Never commit a real bot token or webhook secret.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET="replace-with-output-of-openssl-rand-hex-32"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="VPNthe1_bot"
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL="https://t.me/VPNthe1_bot"

# Remnawave panel connection. Comma-separate inbound UUIDs when there are several.
REMNAWAVE_BASE_URL="https://1vpnpanel.ru/"
REMNAWAVE_API_TOKEN=""
REMNAWAVE_DEFAULT_INBOUND_UUIDS=""

# Public documents and support contacts.
NEXT_PUBLIC_OFFER_URL="https://graph.org/PUBLICHNAYA-OFERTA-04-07-17"
NEXT_PUBLIC_PRIVACY_URL="https://graph.org/POLITIKA-KONFIDENCIALNOSTI-04-07-46"
SUPPORT_EMAIL=""
NEXT_PUBLIC_SUPPORT_EMAIL=""

# Optional SMTP email delivery. Leave SMTP_HOST and SMTP_FROM_EMAIL empty to disable it.
SMTP_HOST=""
SMTP_CONNECT_HOST=""
SMTP_IP_FAMILY="auto"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="1VPN"

# Lifecycle processing and demo payments.
CRON_SECRET="replace-with-output-of-openssl-rand-base64-32"
PAYMENTS_AUTO_APPROVE="false"
