# Core application. Keep DATABASE_URL unchanged when using the bundled SQLite setup.
DATABASE_URL="file:./production.db"
NEXTAUTH_URL="https://the1vpn.ru"
NEXTAUTH_SECRET="replace-with-output-of-openssl-rand-base64-32"

# The seed command creates or updates this administrator.
ADMIN_EMAIL="admin@the1vpn.ru"
ADMIN_PASSWORD="replace-with-a-strong-password-of-at-least-8-characters"

# Optional hCaptcha. Leave both values empty and keep CAPTCHA disabled in admin to disable it.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET_KEY=""

# Telegram linking and lifecycle notifications.
# Never commit a real bot token or webhook secret.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET="replace-with-output-of-openssl-rand-hex-32"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="VPNthe1_bot"
NEXT_PUBLIC_SUPPORT_TELEGRAM_URL="https://t.me/the1vpnsupport"

# Remnawave panel connection. Comma-separate inbound UUIDs when there are several.
REMNAWAVE_BASE_URL="https://1vpnpanel.ru/"
REMNAWAVE_API_TOKEN=""
REMNAWAVE_DEFAULT_INBOUND_UUIDS=""

# Automatic node provisioning. Keep DRY_RUN=true until every token/product/SSH value is checked.
# With AEZA_PRODUCT_ID_* filled, the site auto-generates nd1, nd2, nd3, nd4... up to
# AUTO_PROVISION_MAX_SERVERS, rotating through available locations.
# Optional manual override format for AUTO_PROVISION_TARGETS:
# key|Location name|COUNTRY_CODE|nodeName|subdomain|aezaProductId,key2|Location|CC|node2|nd2|product2
AUTO_PROVISION_ENABLED="false"
AUTO_PROVISION_DRY_RUN="true"
AUTO_PROVISION_TARGETS=""
AUTO_PROVISION_DOMAIN="the1vpn.ru"
AUTO_PROVISION_MEMBER_LIMIT="60"
AUTO_PROVISION_MAX_SERVERS="3"
AUTO_PROVISION_BATCH_SIZE="1"
AUTO_PROVISION_NODE_PORT="2222"
AUTO_PROVISION_HOST_PORT="443"
AUTO_PROVISION_PANEL_IP=""
AUTO_PROVISION_CERTBOT_EMAIL="admin@the1vpn.ru"
AUTO_PROVISION_SSH_USER="root"
AUTO_PROVISION_SSH_PRIVATE_KEY_PATH="/var/www/site1vpn/secrets/provision_key"
AUTO_PROVISION_SSH_CONNECT_TIMEOUT_SECONDS="20"
AUTO_PROVISION_REMNANODE_SECRET_KEY="replace-with-remnawave-node-secret-key"
AUTO_PROVISION_DOCKER_USERNAME=""
AUTO_PROVISION_DOCKER_TOKEN=""
AEZA_API_TOKEN=""
AEZA_PRODUCT_ID_AMSTERDAM=""
AEZA_PRODUCT_ID_VIENNA=""
AEZA_PRODUCT_ID_HELSINKI=""
AEZA_TERM="month"
AEZA_AUTO_PROLONG="false"
AEZA_OS_ID="940"
AEZA_RECIPE=""
AEZA_ORDER_PARAMETERS_JSON=""
TIMEWEB_CLOUD_TOKEN=""
TIMEWEB_DOMAIN="the1vpn.ru"
TIMEWEB_DNS_TTL="600"

# Public documents and support contacts.
NEXT_PUBLIC_OFFER_URL="https://telegra.ph/PUBLICHNAYA-OFERTA-na-okazanie-uslug-po-predostavleniyu-dostupa-k-servisu-1VPN-06-17"
NEXT_PUBLIC_PRIVACY_URL="https://telegra.ph/POLITIKA-KONFIDENCIALNOSTI-i-obrabotki-personalnyh-dannyh-servisa-1VPN-06-17"
SUPPORT_EMAIL=""
NEXT_PUBLIC_SUPPORT_EMAIL=""

# Optional SMTP email delivery. Leave SMTP_HOST and SMTP_FROM_EMAIL empty to disable it.
SMTP_HOST=""
SMTP_CONNECT_HOST=""
SMTP_IP_FAMILY="auto"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="1VPN"

# Lifecycle processing and demo payments.
CRON_SECRET="replace-with-output-of-openssl-rand-base64-32"
PAYMENTS_AUTO_APPROVE="false"

# YooKassa payments. Webhook URL:
# https://the1vpn.ru/api/payments/yookassa/webhook?secret=YOOKASSA_WEBHOOK_SECRET
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_RETURN_URL="https://the1vpn.ru/dashboard"
YOOKASSA_WEBHOOK_SECRET="replace-with-output-of-openssl-rand-hex-32"
