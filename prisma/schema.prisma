generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum VpnProvisionState {
  PENDING
  ACTIVE
  DISABLED
  DELETED
  ERROR
}

enum TransactionType {
  TOPUP
  TRIAL
  ADMIN_ADJUSTMENT
  BILLING_DEBIT
}

enum NotificationType {
  TOPUP
  EXPIRING_SOON
  EXPIRED
  DELETION_WARNING
  DELETED
  BANNED
  UNBANNED
}

model User {
  id                String             @id @default(cuid())
  publicId          String?            @unique
  email             String             @unique
  passwordHash      String?
  emailVerified     DateTime?
  pendingEmail      String?
  passwordlessEnabled Boolean          @default(false)
  isEmailPlaceholder Boolean           @default(false)
  role              Role               @default(USER)
  telegramId        String?            @unique
  telegramUsername  String?
  telegramFirstName String?
  telegramPhotoUrl  String?
  balanceKopeks     Int                @default(0)
  billingCarryMicros BigInt            @default(0)
  billingStartedAt  DateTime?
  lastBillingAt     DateTime?
  billingCycle      Int                @default(0)
  subscriptionEndedAt DateTime?
  removalScheduledAt DateTime?
  isBanned          Boolean            @default(false)
  bannedAt          DateTime?
  trialClaimedAt    DateTime?
  hwidDeviceLimit   Int?
  vpnProvisionState VpnProvisionState  @default(PENDING)
  vpnStatusMessage  String?
  remnawaveUserUuid String?            @unique
  remnawaveShortUuid String?           @unique
  subscriptionUrl   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  squadId           String?

  squad         Squad?              @relation(fields: [squadId], references: [id], onDelete: SetNull)
  transactions  BalanceTransaction[]
  notifications NotificationEvent[]
  accounts      Account[]
  sessions      Session[]
}

model Squad {
  id                       String   @id @default(cuid())
  name                     String   @unique
  slug                     String   @unique
  memberLimit              Int
  position                 Int      @default(0)
  isActive                 Boolean  @default(true)
  remnawaveInternalSquadUuid String? @unique
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  users User[]
}

model BalanceTransaction {
  id           String          @id @default(cuid())
  userId       String
  type         TransactionType
  amountKopeks Int
  description  String
  metadata     Json?
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model NotificationEvent {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  cycleKey  String
  success   Boolean          @default(false)
  message   String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, cycleKey])
  @@index([userId, createdAt])
}

model SystemSettings {
  id                 String   @id @default("default")
  siteName           String   @default("1VPN")
  pricePerDayKopeks  Int      @default(4900)
  trialDays          Int      @default(1)
  deletionGraceHours Int      @default(20)
  defaultHwidDeviceLimit Int  @default(3)
  captchaEnabled     Boolean  @default(false)
  paymentsMode       String   @default("demo")
  supportTelegramUrl String?
  heroAnnouncement   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
